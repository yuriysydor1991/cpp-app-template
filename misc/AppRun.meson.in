#!/bin/sh
#
# AppRun entry point for the @PROJECT_BINARY_NAME@ AppImage bundle.
# Generated by the Meson `template-project-AppImage-enabler` module.
#
# The bundle layout follows whatever meson `--prefix` was used at setup
# time (default `/usr/local`). To force the standard AppImage `AppDir/usr/bin`
# layout reconfigure the build dir with `meson configure --prefix=/usr`
# before running the `AppImage` target.
#
HERE="$(dirname "$(readlink -f "${0}")")"

BIN="$(find "${HERE}" -name "@PROJECT_BINARY_NAME@" -type f -executable 2>/dev/null | head -1)"
if [ -z "${BIN}" ]; then
  BIN="${HERE}/usr/@PROJECT_BINARY_INSTALLATION_DIR@/@PROJECT_BINARY_NAME@"
fi

BIN_DIR="$(dirname "${BIN}")"
LIB_DIR="$(dirname "${BIN_DIR}")/lib"

export PATH="${BIN_DIR}:${PATH}"
export LD_LIBRARY_PATH="${LIB_DIR}:${LIB_DIR}64:${LD_LIBRARY_PATH}"
export XDG_DATA_DIRS="${HERE}/usr/share:${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"

exec "${BIN}" "$@"
