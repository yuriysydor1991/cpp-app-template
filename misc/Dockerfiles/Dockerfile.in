FROM ${DOCKERFILE_SINGLE_RUN_BASE_IMAGE_STRING}

RUN apt update
RUN apt install -y libstdc++6 build-essential git cmake g++
RUN apt install -y libsfml-dev

ARG prefixD=/usr
ARG srcD = /src

WORKDIR $srcD

ARG plotgenD=PlotGenCpp
ARG plotgenB=PlotGenCpp-build

RUN git clone https://github.com/skhelladi/PlotGenCpp.git PlotGenCpp $plotgenD
RUN cmake -B $plotgenB -S $plotgenD -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=$prefixD
RUN cmake --build $plotgenB -j$(nproc)
RUN cmake --install $plotgenB --prefix $prefixD

ARG BUILDDIR=/src/${PROJECT_BINARY_NAME}-build-docker-singlerun

RUN --mount=from=project,target=/src/${PROJECT_BINARY_NAME} \ 
 cd /src/${PROJECT_BINARY_NAME} && \
 mkdir -vp $BUILDDIR && \
 cmake -S . -B $BUILDDIR -DCMAKE_BUILD_TYPE=Release &&  \
 cmake --build $BUILDDIR -j$(nproc) --target ${PROJECT_BINARY_NAME} && \
 cmake --install $BUILDDIR --prefix ${prefixD}

CMD ["${PROJECT_BINARY_NAME}"]
