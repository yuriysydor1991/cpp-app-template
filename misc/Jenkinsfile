pipeline {
  // WinUI 3 + C++/WinRT is a Windows-only stack, so this pipeline expects a
  // Windows build agent with Visual Studio 2022 (MSVC + CMake + ctest) and the
  // Windows App SDK / NuGet available. Label your Jenkins Windows node 'windows'
  // (or adjust the agent below).
  agent { label 'windows' }

  environment {
    BUILDDIR = 'build'
    BDJUNITOUT = 'junit-out'
    CMAKE_GENERATOR = 'Visual Studio 17 2022'
  }

  parameters {
    booleanParam(name: 'RUN_CPPCHECK', defaultValue: false, description: 'Run the cppcheck static code check?')
  }

  stages {
    stage('Checkout') {
      when {
        expression { return !fileExists('CMakeLists.txt') }
      }

      steps {
        git branch: 'appWinUI3',
            url: 'https://github.com/yuriysydor1991/cpp-app-template.git'
      }
    }

    stage('Configure') {
      steps {
        bat 'cmake -S . -B %BUILDDIR% -G "%CMAKE_GENERATOR%" -A x64 ^
              -DENABLE_UNIT_TESTS=ON -DENABLE_COMPONENT_TESTS=ON ^
              -DENABLE_WIX=ON -DMAX_LOG_LEVEL=5'
      }
    }

    stage('Build (Debug)') {
      steps {
        bat 'cmake --build %BUILDDIR% --config Debug'
      }
    }

    stage('cppcheck') {
      when {
        expression { params.RUN_CPPCHECK }
      }
      steps {
        bat 'cmake --build %BUILDDIR% --config Debug --target cppcheck'
      }
    }

    stage('Unit Tests') {
      parallel {
        stage('UTEST_Application') {
          steps {
            bat 'cd %BUILDDIR% && ctest -C Debug -R "UTEST_Application\\." --output-on-failure --output-junit %BDJUNITOUT%/UTEST_Application.junit.xml'
          }
        }
        stage('UTEST_ApplicationContext') {
          steps {
            bat 'cd %BUILDDIR% && ctest -C Debug -R "UTEST_ApplicationContext\\." --output-on-failure --output-junit %BDJUNITOUT%/UTEST_ApplicationContext.junit.xml'
          }
        }
        stage('UTEST_ApplicationFactory') {
          steps {
            bat 'cd %BUILDDIR% && ctest -C Debug -R "UTEST_ApplicationFactory\\." --output-on-failure --output-junit %BDJUNITOUT%/UTEST_ApplicationFactory.junit.xml'
          }
        }
        stage('UTEST_ApplicationHelpPrinter') {
          steps {
            bat 'cd %BUILDDIR% && ctest -C Debug -R "UTEST_ApplicationHelpPrinter\\." --output-on-failure --output-junit %BDJUNITOUT%/UTEST_ApplicationHelpPrinter.junit.xml'
          }
        }
        stage('UTEST_ApplicationVersionPrinter') {
          steps {
            bat 'cd %BUILDDIR% && ctest -C Debug -R "UTEST_ApplicationVersionPrinter\\." --output-on-failure --output-junit %BDJUNITOUT%/UTEST_ApplicationVersionPrinter.junit.xml'
          }
        }
        stage('UTEST_CommandLineParser') {
          steps {
            bat 'cd %BUILDDIR% && ctest -C Debug -R "UTEST_CommandLineParser\\." --output-on-failure --output-junit %BDJUNITOUT%/UTEST_CommandLineParser.junit.xml'
          }
        }
        stage('UTEST_WindowConfig') {
          steps {
            bat 'cd %BUILDDIR% && ctest -C Debug -R "UTEST_WindowConfig\\." --output-on-failure --output-junit %BDJUNITOUT%/UTEST_WindowConfig.junit.xml'
          }
        }
        stage('UTEST_WinUI3Initer') {
          steps {
            bat 'cd %BUILDDIR% && ctest -C Debug -R "UTEST_WinUI3Initer\\." --output-on-failure --output-junit %BDJUNITOUT%/UTEST_WinUI3Initer.junit.xml'
          }
        }
      }
      post { always { junit "${BUILDDIR}/${BDJUNITOUT}/UTEST_*.xml" } }
    }

    stage('Component Tests') {
      parallel {
        stage('CTEST_SimpleLogger') {
          steps {
            bat 'cd %BUILDDIR% && ctest -C Debug -R "CTEST_SimpleLogger\\." --output-on-failure --output-junit %BDJUNITOUT%/CTEST_SimpleLogger.junit.xml'
          }
        }
        stage('CTEST_app') {
          steps {
            bat 'cd %BUILDDIR% && ctest -C Debug -R "CTEST_app\\." --output-on-failure --output-junit %BDJUNITOUT%/CTEST_app.junit.xml'
          }
        }
        stage('CTEST_WinUI3') {
          steps {
            bat 'cd %BUILDDIR% && ctest -C Debug -R "CTEST_WinUI3\\." --output-on-failure --output-junit %BDJUNITOUT%/CTEST_WinUI3.junit.xml'
          }
        }
      }
      post { always { junit "${BUILDDIR}/${BDJUNITOUT}/CTEST_*.xml" } }
    }

    stage('Build (Release)') {
      steps {
        bat 'cmake --build %BUILDDIR% --config Release'
      }
    }

    stage('Release install') {
      steps {
        bat 'cmake --install %BUILDDIR% --config Release --prefix %BUILDDIR%\\install-try'
      }
    }

    stage('WIX package') {
      steps {
        bat 'cd %BUILDDIR% && cpack -C Release -G WIX'
      }
    }
  }

  post {
    success {
      echo '✅ Builds & Tests passed!'
    }
    failure {
      echo '❌ Builds or Tests failed!'
    }
  }
}
