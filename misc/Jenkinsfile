pipeline {
  agent any
  
  environment {
    BUILDDIR="build"
    BDJUNITOUT="junit-out"
  }

  parameters {
    booleanParam(name: 'RUN_CPPCHECK', defaultValue: false, description: 'Run the cppcheck static code check?')
    // Template project specific: optional packager checks, all disabled by
    // default and opt-in (e.g. WIX is MS Windows only, FreeBSD pkg is FreeBSD
    // only). Safe to drop together with the template stages below.
    booleanParam(name: 'RUN_FLATPAK_PACKAGER', defaultValue: false, description: 'Template: build and check the flatpak package?')
    booleanParam(name: 'RUN_DEB_PACKAGER', defaultValue: false, description: 'Template: build and check the deb package?')
    booleanParam(name: 'RUN_RPM_PACKAGER', defaultValue: false, description: 'Template: build and check the RPM package?')
    booleanParam(name: 'RUN_SNAP_PACKAGER', defaultValue: false, description: 'Template: build and check the snap package?')
    booleanParam(name: 'RUN_FREEBSD_PACKAGER', defaultValue: false, description: 'Template: build and check the FreeBSD pkg package? (FreeBSD only)')
    booleanParam(name: 'RUN_WIX_PACKAGER', defaultValue: false, description: 'Template: build and check the WIX MSI package? (MS Windows only)')
  }

  stages {
    stage('Checkout') {
      when {
        expression {
          def files = sh(script: 'ls -A', returnStdout: true).trim()
          return files == ""
        }
      }
      
      steps {
        git branch: 'appOpenCV',
            url: 'https://github.com/yuriysydor1991/cpp-app-template.git'
      }
    }
    
    stage('Code format configure') {
      steps {
        sh '''
          cmake -S . -B $BUILDDIR -DCMAKE_BUILD_TYPE=Debug -DENABLE_CLANGFORMAT=ON
        '''
      }
    }
    
    stage('Code format build (clang-format)') {
      steps {
        script {
          def files = sh(script: 'git ls-files -m', returnStdout: true).trim()
          return files == ""
        }
      }
      
      post {
        success {
          echo 'No files changed - OK'
        }
        failure {
          echo 'Some files are not formatted - FAIL'
        }
      }
    }

    stage('Debug configure') {
      steps {
        sh 'rm -fr $BUILDDIR'
        sh '''
          cmake -S . -B $BUILDDIR -DCMAKE_BUILD_TYPE=Debug -DENABLE_UNIT_TESTS=ON \
            -DENABLE_SANITIZERS=ON -DENABLE_CPPCHECK=ON \
            -DMAX_LOG_LEVEL=5 -DENABLE_COMPONENT_TESTS=ON
        '''
      }
    }
    
    stage('Debug build') {
      steps {
        sh '''
          cmake --build $BUILDDIR -j$(nproc)
        '''
      }
    }
    
    stage('cppcheck') {
      when {
        expression { params.RUN_CPPCHECK }
      }
      steps {
        sh '''
          cmake --build $BUILDDIR -j$(nproc) --target cppcheck
        '''
      }
    }
    
    stage('Unit Tests') {
      parallel {
        stage('UTEST_Application') { 
          steps { 
            sh 'cd $BUILDDIR && ctest -R "UTEST_Application\\." --output-on-failure --output-junit $BDJUNITOUT/UTEST_Application.junit.xml'
          }
        }
        stage('UTEST_ApplicationContext') { 
          steps { 
            sh 'cd $BUILDDIR && ctest -R "UTEST_ApplicationContext\\." --output-on-failure --output-junit $BDJUNITOUT/UTEST_ApplicationContext.junit.xml'
          }
        }
        stage('UTEST_ApplicationFactory') { 
          steps { 
            sh 'cd $BUILDDIR && ctest -R "UTEST_ApplicationFactory\\." --output-on-failure --output-junit $BDJUNITOUT/UTEST_ApplicationFactory.junit.xml'
          }
        }
        stage('UTEST_ApplicationHelpPrinter') { 
          steps { 
            sh 'cd $BUILDDIR && ctest -R "UTEST_ApplicationHelpPrinter\\." --output-on-failure --output-junit $BDJUNITOUT/UTEST_ApplicationHelpPrinter.junit.xml' 
          }
        }
        stage('UTEST_ApplicationVersionPrinter') { 
          steps { 
            sh 'cd $BUILDDIR && ctest -R "UTEST_ApplicationVersionPrinter\\." --output-on-failure --output-junit $BDJUNITOUT/UTEST_ApplicationVersionPrinter.junit.xml'
          }
        }
        stage('UTEST_CommandLineParser') {
          steps {
            sh 'cd $BUILDDIR && ctest -R "UTEST_CommandLineParser\\." --output-on-failure --output-junit $BDJUNITOUT/UTEST_CommandLineParser.junit.xml'
          }
        }
        stage('UTEST_OpenCVController') {
          steps {
            sh 'cd $BUILDDIR && ctest -R "UTEST_OpenCVController\\." --output-on-failure --output-junit $BDJUNITOUT/UTEST_OpenCVController.junit.xml'
          }
        }
      }
      post { always { junit "$BUILDDIR/$BDJUNITOUT/UTEST_*.xml" } }
    }

    stage('Component Tests') {
      parallel {
        stage('CTEST_DefaultLogger') {
          steps {
            sh 'cd $BUILDDIR && ctest -R "CTEST_DefaultLogger\\." --output-on-failure --output-junit $BDJUNITOUT/CTEST_DefaultLogger.junit.xml'
          }
        }
        stage('CTEST_log') {
          steps {
            sh 'cd $BUILDDIR && ctest -R "CTEST_log\\." --output-on-failure --output-junit $BDJUNITOUT/CTEST_log.junit.xml'
          }
        }
        stage('CTEST_app') {
          steps {
            sh 'cd $BUILDDIR && ctest -R "CTEST_app\\." --output-on-failure --output-junit $BDJUNITOUT/CTEST_app.junit.xml'
          }
        }
        stage('CTEST_opencv') {
          steps {
            sh 'cd $BUILDDIR && ctest -R "CTEST_opencv\\." --output-on-failure --output-junit $BDJUNITOUT/CTEST_opencv.junit.xml'
          }
        }
      }
      post { always { junit "$BUILDDIR/$BDJUNITOUT/CTEST_*.xml" } }
    }
    
    stage('Debug configure (clang-tidy)') {
      steps {
        sh 'rm -fr $BUILDDIR'
        sh '''
          cmake -S . -B $BUILDDIR -DCMAKE_BUILD_TYPE=Debug -DENABLE_CLANG_TIDY=ON \
            -DMAX_LOG_LEVEL=5
        '''
      }
    }
    
    stage('Debug build (clang-tidy)') {
      steps {
        sh '''
          cmake --build $BUILDDIR -j$(nproc)
        '''
      }
    }
    
    stage('Release configure') {
      steps {
        sh 'rm -fr $BUILDDIR'
        sh '''
          cmake -S . -B $BUILDDIR -DCMAKE_BUILD_TYPE=Release
        '''
      }
    }
    
    stage('Release build') {
      steps {
        sh '''
          cmake --build $BUILDDIR -j$(nproc)
        '''
      }
    }
    
    stage('Release install') {
      steps {
        sh '''
          cmake --install $BUILDDIR --prefix $BUILDDIR/install-try
        '''
      }
    }

    // =====================================================================
    // Template project specific checks.
    //
    // Everything below is specific to the cpp-app-template project itself and
    // is safe to delete in a real project implementation derived from this
    // template. The stages are written generically - they discover the doc
    // sections, the enablers, the declared tests and the produced packages
    // dynamically, with no hardcoded names - so they can be reused as-is on
    // the other template branches.
    // =====================================================================

    stage('Template: no git conflict markers') {
      steps {
        sh '''
          if git grep -nE "^(<<<<<<<|>>>>>>>)" -- .; then
            echo "FAIL: the files listed above contain git conflict markers (unmerged content)"
            exit 1
          fi
          echo "OK: no git conflict markers found in the tracked files"
        '''
      }
    }

    stage('Template: no en_US doc sections in the uk_UA README') {
      steps {
        sh '''
          if grep -nE "doc/sections/en_US/" doc/README.uk_UA.md; then
            echo "FAIL: the uk_UA README links en_US sections; it must use uk_UA sections only"
            exit 1
          fi
          echo "OK: the uk_UA README references no en_US sections"
        '''
      }
    }

    stage('Template: no uk_UA doc sections in the top-level README') {
      steps {
        sh '''
          if grep -nE "doc/sections/uk_UA/" README.md; then
            echo "FAIL: the top-level README links uk_UA sections; it must use en_US sections only"
            exit 1
          fi
          echo "OK: the top-level README references no uk_UA sections"
        '''
      }
    }

    stage('Template: every doc section is linked in its README') {
      steps {
        sh '''
          status=0
          for langdir in doc/sections/*/; do
            [ -d "$langdir" ] || continue
            lang="$(basename "$langdir")"
            if [ "$lang" = "en_US" ]; then
              readme="README.md"
            else
              readme="doc/README.${lang}.md"
            fi
            if [ ! -f "$readme" ]; then
              echo "FAIL: no README ($readme) found for the doc/sections/$lang language"
              status=1
              continue
            fi
            for f in "$langdir"*; do
              [ -f "$f" ] || continue
              if ! grep -qF "$f" "$readme"; then
                echo "FAIL: $f is not linked in $readme"
                status=1
              fi
            done
          done
          [ "$status" -eq 0 ] || exit 1
          echo "OK: every doc/sections file is linked in its README"
        '''
      }
    }

    stage('Template: every enabler is registered') {
      steps {
        sh '''
          included="$( { cat cmake/template-project-feature-enabler.cmake cmake/template-project-feature-enabler-post.cmake; find cmake/enablers -name "*.cmake" -exec cat {} +; } | grep "include(" | sed "s/.*include(//; s/).*//" | tr -d " " | sort -u )"
          status=0
          for f in $(find cmake/enablers -name "*.cmake" | sort); do
            mod="$(basename "$f" .cmake)"
            if ! echo "$included" | grep -qx "$mod"; then
              echo "FAIL: enabler $mod ($f) is not registered in the template-project-feature-enabler files"
              status=1
            fi
          done
          [ "$status" -eq 0 ] || exit 1
          echo "OK: every enabler under cmake/enablers is registered"
        '''
      }
    }

    stage('Template: every declared test is registered in the pipeline') {
      steps {
        sh '''
          declared="$(grep -rA3 "gtest_add_tests" --include=CMakeLists.txt src | grep -oE "TARGET[[:space:]]+[A-Za-z0-9_]+" | awk '{print $2}' | sort -u)"
          status=0
          for t in $declared; do
            if ! grep -qF "$t" misc/Jenkinsfile; then
              echo "FAIL: test $t is declared in the CMake files but not registered in this Jenkinsfile"
              status=1
            fi
          done
          [ "$status" -eq 0 ] || exit 1
          echo "OK: every CMake-declared test is registered in the pipeline"
        '''
      }
    }

    // Packager checks are intentionally separate sequential stages (not a
    // parallel block): each runs a full CMake configure + build, so running
    // them in parallel could overload the build agent.
    stage('Template: flatpak package') {
      when { expression { params.RUN_FLATPAK_PACKAGER } }
      steps {
        sh '''
          BD="$BUILDDIR-pkg-flatpak"
          rm -fr "$BD"
          cmake -S . -B "$BD" -DCMAKE_BUILD_TYPE=Release -DENABLE_FLATPAK=ON
          cmake --build "$BD" -j$(nproc)
          cmake --build "$BD" --target flatpak
          if [ -z "$(find "$BD" -maxdepth 2 -name '*.flatpak' -print -quit)" ]; then
            echo "FAIL: CMake did not produce a .flatpak bundle"
            exit 1
          fi
          echo "OK: produced $(find "$BD" -maxdepth 2 -name '*.flatpak')"
        '''
      }
    }

    stage('Template: deb package') {
      when { expression { params.RUN_DEB_PACKAGER } }
      steps {
        sh '''
          BD="$BUILDDIR-pkg-deb"
          rm -fr "$BD"
          cmake -S . -B "$BD" -DCMAKE_BUILD_TYPE=Release -DENABLE_DEB=ON
          cmake --build "$BD" -j$(nproc)
          ( cd "$BD" && cpack -G DEB )
          if [ -z "$(find "$BD" -maxdepth 2 -name '*.deb' -print -quit)" ]; then
            echo "FAIL: CMake/CPack did not produce a .deb package"
            exit 1
          fi
          echo "OK: produced $(find "$BD" -maxdepth 2 -name '*.deb')"
        '''
      }
    }

    stage('Template: rpm package') {
      when { expression { params.RUN_RPM_PACKAGER } }
      steps {
        sh '''
          BD="$BUILDDIR-pkg-rpm"
          rm -fr "$BD"
          cmake -S . -B "$BD" -DCMAKE_BUILD_TYPE=Release -DENABLE_RPM=ON
          cmake --build "$BD" -j$(nproc)
          ( cd "$BD" && cpack -G RPM )
          if [ -z "$(find "$BD" -maxdepth 2 -name '*.rpm' -print -quit)" ]; then
            echo "FAIL: CMake/CPack did not produce a .rpm package"
            exit 1
          fi
          echo "OK: produced $(find "$BD" -maxdepth 2 -name '*.rpm')"
        '''
      }
    }

    stage('Template: snap package') {
      when { expression { params.RUN_SNAP_PACKAGER } }
      steps {
        sh '''
          BD="$BUILDDIR-pkg-snap"
          rm -fr "$BD"
          cmake -S . -B "$BD" -DCMAKE_BUILD_TYPE=Release -DENABLE_SNAP=ON
          cmake --build "$BD" -j$(nproc)
          cmake --build "$BD" --target snap
          if [ -z "$(find "$BD" -maxdepth 3 -name '*.snap' -print -quit)" ]; then
            echo "FAIL: CMake did not produce a .snap package"
            exit 1
          fi
          echo "OK: produced $(find "$BD" -maxdepth 3 -name '*.snap')"
        '''
      }
    }

    stage('Template: freebsd-pkg package') {
      when { expression { params.RUN_FREEBSD_PACKAGER } }
      steps {
        sh '''
          BD="$BUILDDIR-pkg-freebsd"
          rm -fr "$BD"
          cmake -S . -B "$BD" -DCMAKE_BUILD_TYPE=Release -DENABLE_FREEBSD_PKG=ON
          cmake --build "$BD" -j$(nproc)
          ( cd "$BD" && cpack -G FREEBSD )
          if [ -z "$(find "$BD" -maxdepth 2 -name '*.pkg' -print -quit)" ]; then
            echo "FAIL: CMake/CPack did not produce a FreeBSD .pkg package"
            exit 1
          fi
          echo "OK: produced $(find "$BD" -maxdepth 2 -name '*.pkg')"
        '''
      }
    }

    stage('Template: wix-msi package') {
      when { expression { params.RUN_WIX_PACKAGER } }
      steps {
        sh '''
          BD="$BUILDDIR-pkg-wix"
          rm -fr "$BD"
          cmake -S . -B "$BD" -DCMAKE_BUILD_TYPE=Release -DENABLE_WIX=ON
          cmake --build "$BD" -j$(nproc)
          ( cd "$BD" && cpack -G WIX )
          if [ -z "$(find "$BD" -maxdepth 2 -name '*.msi' -print -quit)" ]; then
            echo "FAIL: CMake/CPack did not produce a .msi package"
            exit 1
          fi
          echo "OK: produced $(find "$BD" -maxdepth 2 -name '*.msi')"
        '''
      }
    }
  }

  post {
    success {
      echo '✅ Builds & Tests passed!'
    }
    failure {
      echo '❌ Builds or Tests failed!'
    }
  }
}

