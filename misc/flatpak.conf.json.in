{
  "id": "${FLATPAK_PROJECT_URL}",
  "runtime": "org.gnome.Platform",
  "runtime-version": "48",
  "sdk": "org.gnome.Sdk",
  "command": "${PROJECT_BINARY_NAME}",
  "modules": [
    {
      "comment": "The project builds wxWidgets from source through CMake FetchContent, so the build needs network access and the GNOME SDK (which provides the GTK development files used by the wxWidgets GTK backend).",
      "name": "${PROJECT_NAME}",
      "buildsystem": "cmake",
      "config-opts": ["-DCMAKE_BUILD_TYPE=Release"],
      "build-options": {
        "build-args": [ "--share=network" ]
      },
      "sources": [
        {
          "type": "dir",
          "path": "${CMAKE_SOURCE_DIR}"
        }
      ]
    }
  ],
  "finish-args": [
    "--filesystem=/run/host",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--talk-name=org.freedesktop.DBus",
    "--talk-name=org.freedesktop.Notifications",
    "--own-name=${FLATPAK_PROJECT_URL}"
  ]
}
