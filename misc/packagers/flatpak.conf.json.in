{
  "id": "${FLATPAK_PROJECT_URL}",
  "runtime": "org.kde.Platform",
  "runtime-version": "6.8",
  "sdk": "org.kde.Sdk",
  "command": "${PROJECT_BINARY_NAME}",
  "modules": [
    {
      "name": "gnuplot",
      "buildsystem": "simple",
      "builddir": true,
      "sources": [
        {
          "type": "git",
          "url": "https://git.code.sf.net/p/gnuplot/gnuplot-main",
          "tag": "branch-5-4-stable"
        }
      ],
       "build-commands": [
        "./prepare",
        "./configure --prefix=/app --without-lua --without-x",
        "make -j$(nproc)",
        "make install"
      ]
    },
    {
      "name": "matplotplusplus",
      "buildsystem": "cmake",
      "config-opts": [
        "-DCMAKE_INSTALL_PREFIX=/app",
        "-DMATPLOTPP_BUILD_EXAMPLES=OFF",
        "-DMATPLOTPP_BUILD_SHARED_LIBS=ON",
        "-DMATPLOTPP_BUILD_TESTS=OFF",
        "-DCMAKE_BUILD_TYPE=Release",
        "-DCMAKE_INTERPROCEDURAL_OPTIMIZATION=ON"
      ], 
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/alandefreitas/matplotplusplus.git",
          "tag": "master"
        }
      ]
    },
    {
      "name": "${PROJECT_NAME}",
      "buildsystem": "cmake",
      "config-opts": ["-DCMAKE_BUILD_TYPE=Release"],
      "sources": [
        {
          "type": "dir",
          "path": "${CMAKE_SOURCE_DIR}"
        }
      ]
    }
  ],
  "finish-args": [
    "--share=ipc", 
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri"
  ]
}
