{
  "id": "${FLATPAK_PROJECT_URL}",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "${PROJECT_BINARY_NAME}",
  "modules": [
    {
      "comment": "Builds the Firebird client library (libfbclient) from the official sources and installs it into the /app prefix. The maintainer may need to pin the commit and tune the build options for the chosen Firebird version.",
      "name": "firebird",
      "buildsystem": "simple",
      "build-commands": [
        "./autogen.sh --prefix=/app --with-builtin-tommath --without-fbsample --without-fbsample-db",
        "make -j$(nproc)",
        "make install"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/FirebirdSQL/firebird.git",
          "tag": "v4.0.5"
        }
      ]
    },
    {
      "name": "${CMAKE_PROJECT_NAME}",
      "buildsystem": "cmake",
      "config-opts": [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DCMAKE_PREFIX_PATH=/app"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "${CMAKE_SOURCE_DIR}"
        }
      ]
    }
  ],
  "finish-args": [
    "--env=LD_LIBRARY_PATH=/app/lib:/app/lib64",
    "--share=network"
  ]
}
