name: @PROJECT_BINARY_NAME_lower@
base: core24
version: '@PROJECT_VERSION@'
summary: @PROJECT_DESCRIPTION@
description: |
  @PROJECT_DESCRIPTION@

grade: @TEMPLATE_PROJECT_SNAP_GRADE@
confinement: @TEMPLATE_PROJECT_SNAP_CONFINEMENT@

apps:
  @PROJECT_NAME@:
    command: @PROJECT_BINARY_INSTALLATION_DIR@/@PROJECT_NAME@
    plugs:
      - home

parts:
  @PROJECT_NAME@:
    plugin: meson
    source: '@PROJECT_SOURCE_DIR@'
    meson-parameters:
      - --buildtype=release
      - --prefix=/usr
