# Generated by Meson via configure_file - version compatibility helper for find_package.
# Compatibility model: SameMajorVersion (matches the lib branch CMake export).

set(PACKAGE_VERSION "@PROJECT_VERSION@")
set(PACKAGE_VERSION_MAJOR "@PROJECT_VERSION_MAJOR@")

if(NOT PACKAGE_FIND_VERSION)
  set(PACKAGE_VERSION_COMPATIBLE TRUE)
  set(PACKAGE_VERSION_EXACT FALSE)
elseif(PACKAGE_FIND_VERSION_MAJOR STREQUAL PACKAGE_VERSION_MAJOR)
  set(PACKAGE_VERSION_COMPATIBLE TRUE)
  if(PACKAGE_FIND_VERSION VERSION_EQUAL PACKAGE_VERSION)
    set(PACKAGE_VERSION_EXACT TRUE)
  else()
    set(PACKAGE_VERSION_EXACT FALSE)
  endif()
else()
  set(PACKAGE_VERSION_COMPATIBLE FALSE)
  set(PACKAGE_VERSION_EXACT FALSE)
endif()
