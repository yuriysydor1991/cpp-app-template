# Generated by Meson via configure_file - imported targets for downstream CMake.
# Equivalent of the install(EXPORT ...) file the CMake `lib` branch produces.

if(TARGET @PROJECT_LIBRARY_NAME@::@PROJECT_LIBRARY_NAME@)
  return()
endif()

# This file is installed at <prefix>/@CMAKE_CONFIG_INSTALL_DIR@/<name>Targets.cmake.
# Walk back to recover the install prefix.
get_filename_component(_@PROJECT_LIBRARY_NAME@_install_prefix
  "${CMAKE_CURRENT_LIST_DIR}/@RELATIVE_BACK_FROM_CMAKE_DIR@" ABSOLUTE)

add_library(@PROJECT_LIBRARY_NAME@::@PROJECT_LIBRARY_NAME@ SHARED IMPORTED)

set_target_properties(@PROJECT_LIBRARY_NAME@::@PROJECT_LIBRARY_NAME@ PROPERTIES
  INTERFACE_INCLUDE_DIRECTORIES "${_@PROJECT_LIBRARY_NAME@_install_prefix}/@INCLUDE_INSTALL_SUBDIR@"
)

if(CMAKE_SYSTEM_NAME STREQUAL "Windows")
  set_target_properties(@PROJECT_LIBRARY_NAME@::@PROJECT_LIBRARY_NAME@ PROPERTIES
    IMPORTED_LOCATION "${_@PROJECT_LIBRARY_NAME@_install_prefix}/bin/@PROJECT_LIBRARY_NAME@.dll"
    IMPORTED_IMPLIB   "${_@PROJECT_LIBRARY_NAME@_install_prefix}/@LIB_INSTALL_SUBDIR@/@PROJECT_LIBRARY_NAME@.dll.a"
  )
else()
  set_target_properties(@PROJECT_LIBRARY_NAME@::@PROJECT_LIBRARY_NAME@ PROPERTIES
    IMPORTED_LOCATION "${_@PROJECT_LIBRARY_NAME@_install_prefix}/@LIB_INSTALL_SUBDIR@/lib@PROJECT_LIBRARY_NAME@.so.@PROJECT_VERSION@"
    IMPORTED_SONAME   "lib@PROJECT_LIBRARY_NAME@.so.@PROJECT_VERSION_MAJOR@"
  )
endif()

unset(_@PROJECT_LIBRARY_NAME@_install_prefix)
